
  <turbo-frame class='col' id='<%= dom_id(list, 'tasks') %>'> 
    <div id='<%= dom_id list %>' class='list' data-controller="move-task" 
     data-move-task-target='list'  data-action='drop->move-task#dragDrop dragover->move-task#allowDrop'>
      <div class='list-head text-center'>
        <%= list.name %>
      </div>
        <% list.tasks.ordered.each do |task| %>
          <%= render partial: 'tasks/task', locals: { task: task } %>
        <% end %>
    </div>
  </turbo-frame>
