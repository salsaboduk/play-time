{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug server side",
      "type": "rdbg",
      "request": "launch",
      "script": "${workspaceFolder}/bin/rails",
      "args": ["server"],
      "serverReadyAction": {
        "action": "openExternally", 
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/"
      },
    },
    {
      "name": "Internal Browser",
      "request": "launch",
      "type": "editor-browser",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Server/Client",
      "configurations": ["Debug server side", "Internal Browser"],
      "stopAll": true,
      "postLaunchTask": "watch css",
    }
  ]
}
